{
  "personalize.dataset.DatasetGroupArn": {
    "Description": "The Amazon Resource Name (ARN) of the dataset group.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "256",
    "Pattern": "arn:([a-z\\d-]+):personalize:.*:.*:.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.dataset.DatasetImportJob": {
    "Description": "Describes a job that imports training data from a data source (Amazon S3 bucket) to an Amazon Personalize dataset.",
    "Required": "No",
    "Type": "DatasetImportJob",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "personalize.dataset.DatasetType": {
    "Description": "One of the following values:  + Interactions+ Items+ Users",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.dataset.Name": {
    "Description": "The name of the dataset.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "63",
    "Pattern": "^[a-zA-Z0-9][a-zA-Z0-9\\-_]*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.dataset.SchemaArn": {
    "Description": "The ARN of the associated schema.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "256",
    "Pattern": "arn:([a-z\\d-]+):personalize:.*:.*:.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
