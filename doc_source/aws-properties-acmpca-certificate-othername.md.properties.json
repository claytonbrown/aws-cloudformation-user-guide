{
  "acmpca.certificate.othername.CfnAbout": "Defines a custom ASN.1 X.400 `GeneralName` using an object identifier (OID) and value. The OID must satisfy the regular expression shown below. For more information, see NIST's definition of [Object Identifier (OID)](https://csrc.nist.gov/glossary/term/Object_Identifier).",
  "acmpca.certificate.othername.CfnType": "AWS::ACMPCA::Certificate.OtherName",
  "acmpca.certificate.othername.CfnDocsKey": "aws-properties-acmpca-certificate-othername",
  "acmpca.certificate.othername.TypeId": {
    "Description": "Specifies an OID.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "64",
    "Pattern": "^([0-2])\\.([0-9]|([0-3][0-9]))((\\.([0-9]+)){0,126})$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "acmpca.certificate.othername.Value": {
    "Description": "Specifies an OID value.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
