{
  "quicksight.analysis.panelconfiguration.CfnAbout": "A collection of options that configure how each panel displays in a small multiples chart.",
  "quicksight.analysis.panelconfiguration.CfnType": "AWS::QuickSight::Analysis.PanelConfiguration",
  "quicksight.analysis.panelconfiguration.CfnDocsKey": "aws-properties-quicksight-analysis-panelconfiguration",
  "quicksight.analysis.panelconfiguration.BackgroundColor": {
    "Description": "Sets the background color for each panel.",
    "Required": "No",
    "Type": "String",
    "Pattern": "^#[A-F0-9]{6}(?:[A-F0-9]{2})?$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.BackgroundVisibility": {
    "Description": "Determines whether or not a background for each small multiples panel is rendered.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "HIDDEN | VISIBLE",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.BorderColor": {
    "Description": "Sets the line color of panel borders.",
    "Required": "No",
    "Type": "String",
    "Pattern": "^#[A-F0-9]{6}(?:[A-F0-9]{2})?$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.BorderStyle": {
    "Description": "Sets the line style of panel borders.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "DASHED | DOTTED | SOLID",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.BorderThickness": {
    "Description": "Sets the line thickness of panel borders.",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.BorderVisibility": {
    "Description": "Determines whether or not each panel displays a border.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "HIDDEN | VISIBLE",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.GutterSpacing": {
    "Description": "Sets the total amount of negative space to display between sibling panels.",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.GutterVisibility": {
    "Description": "Determines whether or not negative space between sibling panels is rendered.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "HIDDEN | VISIBLE",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.panelconfiguration.Title": {
    "Description": "Configures the title display within each small multiples panel.",
    "Required": "No",
    "Type": "PanelTitleOptions",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
