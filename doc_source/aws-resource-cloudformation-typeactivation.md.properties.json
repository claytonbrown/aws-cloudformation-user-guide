{
  "cloudformation.typeactivation.TypeName": {
    "Pattern": "[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}(::MODULE){0,1}",
    "Required": "Conditional",
    "Maximum": "204",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "10",
    "Type": "String"
  },
  "cloudformation.typeactivation.VersionBump": {
    "Allowed values": "MAJOR | MINOR",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)\n\n#"
  },
  "cloudformation.typeactivation.AutoUpdate": {
    "Required": "No",
    "UpdateRequires": "No interruption",
    "AllowedValues": [
      "True",
      "False"
    ]
  },
  "cloudformation.typeactivation.TypeNameAlias": {
    "Pattern": "[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}(::MODULE){0,1}",
    "Required": "No",
    "Maximum": "204",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "10",
    "Type": "String"
  },
  "cloudformation.typeactivation.PublisherId": {
    "Pattern": "[0-9a-zA-Z]{12,40}",
    "Required": "Conditional",
    "Maximum": "40",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "1",
    "Type": "String"
  },
  "cloudformation.typeactivation.PublicTypeArn": {
    "Pattern": "arn:aws[A-Za-z0-9-]{0,64}:cloudformation:[A-Za-z0-9-]{1,64}::type/.+/[0-9a-zA-Z]{12,40}/.+",
    "Required": "Conditional",
    "Type": "String",
    "Maximum": "1024",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.typeactivation.LoggingConfig": {
    "Required": "No",
    "Type": "LoggingConfig",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.typeactivation.ExecutionRoleArn": {
    "Pattern": "arn:.+:iam::[0-9]{12}:role/.+",
    "Required": "No",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "1",
    "Type": "String"
  },
  "cloudformation.typeactivation.MajorVersion": {
    "Required": "No",
    "UpdateRequires": "No interruption"
  },
  "cloudformation.typeactivation.Type": {
    "Allowed values": "MODULE | RESOURCE",
    "Required": "Conditional",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
