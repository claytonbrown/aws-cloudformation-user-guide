{
  "workspacesweb.usersettings.cookiespecification.CfnAbout": "Specifies a single cookie or set of cookies in an end user's browser.",
  "workspacesweb.usersettings.cookiespecification.CfnType": "AWS::WorkSpacesWeb::UserSettings.CookieSpecification",
  "workspacesweb.usersettings.cookiespecification.CfnDocsKey": "aws-properties-workspacesweb-usersettings-cookiespecification",
  "workspacesweb.usersettings.cookiespecification.Domain": {
    "Description": "The domain of the cookie.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "253",
    "Pattern": "(\\.?)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)*[a-z0-9][a-z0-9-]{0,61}[a-z0-9]",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "workspacesweb.usersettings.cookiespecification.Name": {
    "Description": "The name of the cookie.",
    "Required": "No",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "4096",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "workspacesweb.usersettings.cookiespecification.Path": {
    "Description": "The path of the cookie.",
    "Required": "No",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "2000",
    "Pattern": "/(\\S)*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
