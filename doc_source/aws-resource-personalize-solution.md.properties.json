{
  "personalize.solution.DatasetGroupArn": {
    "Required": "Yes",
    "Type": "String",
    "Maximum": "256",
    "Pattern": "arn:([a-z\\d-]+):personalize:.*:.*:.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.EventType": {
    "Required": "No",
    "Type": "String",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.Name": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "63",
    "Pattern": "^[a-zA-Z0-9][a-zA-Z0-9\\-_]*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.PerformAutoML": {
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.PerformHPO": {
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.RecipeArn": {
    "Required": "No",
    "Type": "String",
    "Maximum": "256",
    "Pattern": "arn:([a-z\\d-]+):personalize:.*:.*:.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.SolutionConfig": {
    "Required": "No",
    "Type": "SolutionConfig",
