{
  "quicksight.dataset.datasetusageconfiguration.CfnAbout": "The usage configuration to apply to child datasets that reference this dataset as a source.",
  "quicksight.dataset.datasetusageconfiguration.CfnType": "AWS::QuickSight::DataSet.DataSetUsageConfiguration",
  "quicksight.dataset.datasetusageconfiguration.CfnDocsKey": "aws-properties-quicksight-dataset-datasetusageconfiguration",
  "quicksight.dataset.datasetusageconfiguration.DisableUseAsDirectQuerySource": {
    "Description": "An option that controls whether a child dataset of a direct query can use this dataset as a source.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.dataset.datasetusageconfiguration.DisableUseAsImportedSource": {
    "Description": "An option that controls whether a child dataset that's stored in QuickSight can use this dataset as a source.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
