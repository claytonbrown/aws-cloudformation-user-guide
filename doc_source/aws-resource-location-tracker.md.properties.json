{
  "location.tracker.TrackerName": {
    "Pattern": "^[-._\\w]+$",
    "Required": "Yes",
    "Maximum": "100",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#",
    "Minimum": "1",
    "Type": "String"
  },
  "location.tracker.KmsKeyId": {
    "Minimum": "1",
    "Required": "No",
    "Type": "String",
    "Maximum": "2048",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "location.tracker.PositionFiltering": {
    "Allowed values": "AccuracyBased | DistanceBased | TimeBased",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "location.tracker.Description": {
    "Minimum": "0",
    "Required": "No",
    "Type": "String",
    "Maximum": "1000",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "location.tracker.PricingPlan": {
    "Allowed values": "MobileAssetManagement | MobileAssetTracking | RequestBasedUsage",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "location.tracker.PricingPlanDataSource": {
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
