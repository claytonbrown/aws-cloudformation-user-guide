{
  "imagebuilder.image.CfnAbout": "An image build version. An image is a customized, secure, and up-to-date “golden” server image that is pre-installed and pre-configured with software and settings to meet specific IT standards.",
  "imagebuilder.image.CfnType": "AWS::ImageBuilder::Image",
  "imagebuilder.image.CfnDocsKey": "aws-resource-imagebuilder-image",
  "imagebuilder.image.ContainerRecipeArn": {
    "Description": "The Amazon Resource Name (ARN) of the container recipe that is used for this pipeline.",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.DistributionConfigurationArn": {
    "Description": "The Amazon Resource Name (ARN) of the distribution configuration.",
    "Required": "No",
    "Type": "String",
    "Pattern": "^arn:aws[^:]*:imagebuilder:[^:]+:(?:[0-9]{12}|aws):(?:image-recipe|container-recipe|infrastructure-configuration|distribution-configuration|component|image|image-pipeline|workflow\\/(?:build|test|distribution))/[a-z0-9-_]+(?:/(?:(?:x|[0-9]+)\\.(?:x|[0-9]+)\\.(?:x|[0-9]+))(?:/[0-9]+)?)?$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.EnhancedImageMetadataEnabled": {
    "Description": "Indicates whether Image Builder collects additional information about the image, such as the operating system (OS) version and package list.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.ImageRecipeArn": {
    "Description": "The Amazon Resource Name (ARN) of the image recipe.",
    "Required": "No",
    "Type": "String",
    "Pattern": "^arn:aws[^:]*:imagebuilder:[^:]+:(?:[0-9]{12}|aws):(?:image-recipe|container-recipe|infrastructure-configuration|distribution-configuration|component|image|image-pipeline|workflow\\/(?:build|test|distribution))/[a-z0-9-_]+(?:/(?:(?:x|[0-9]+)\\.(?:x|[0-9]+)\\.(?:x|[0-9]+))(?:/[0-9]+)?)?$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.ImageScanningConfiguration": {
    "Description": "Contains settings for vulnerability scans.",
    "Required": "No",
    "Type": "ImageScanningConfiguration",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.ImageTestsConfiguration": {
    "Description": "The configuration settings for your image test components, which includes a toggle that allows you to turn off tests, and a timeout setting.",
    "Required": "No",
    "Type": "ImageTestsConfiguration",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.InfrastructureConfigurationArn": {
    "Description": "The Amazon Resource Name (ARN) of the infrastructure configuration associated with this image pipeline.",
    "Required": "Yes",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "imagebuilder.image.Tags": {
    "Description": "The tags of the image.",
    "Required": "No",
    "Type": "Map of String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
