{
  "appflow.flow.s3destinationproperties.BucketName": {
    "Docs": "The Amazon S3 bucket name in which Amazon AppFlow places the transferred data.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "3",
    "Maximum": "63",
    "Pattern": "\\S+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.s3destinationproperties.BucketPrefix": {
    "Docs": "The object key for the destination bucket in which Amazon AppFlow places the files.",
    "Required": "No",
    "Type": "String",
    "Maximum": "512",
    "Pattern": ".*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.s3destinationproperties.S3OutputFormatConfig": {
    "Docs": "The configuration that determines how Amazon AppFlow should format the flow output data when Amazon S3 is used as the destination.",
    "Required": "No",
    "Type": "S3OutputFormatConfig",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)\n\n#"
  }
}
