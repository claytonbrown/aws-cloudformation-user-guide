{
  "gamelift.matchmakingruleset.Name": {
    "Required": "Yes",
    "Type": "String",
    "Maximum": "128",
    "Pattern": "[a-zA-Z0-9-\\.]*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "gamelift.matchmakingruleset.RuleSetBody": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "65535",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "gamelift.matchmakingruleset.Tags": {
    "Required": "No",
    "Maximum": "200",
    "UpdateRequires": "No interruption"
  }
}
