{
  "wisdom.knowledgebase.Name": {
    "Pattern": "^[a-zA-Z0-9\\s_.,-]+",
    "Required": "Yes",
    "Maximum": "255",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "1",
    "Type": "String"
  },
  "wisdom.knowledgebase.Description": {
    "Pattern": "^[a-zA-Z0-9\\s_.,-]+",
    "Required": "No",
    "Maximum": "255",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "1",
    "Type": "String"
  },
  "wisdom.knowledgebase.SourceConfiguration": {
    "Required": "No",
    "Type": "SourceConfiguration",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "wisdom.knowledgebase.ServerSideEncryptionConfiguration": {
    "Required": "No",
    "Type": "ServerSideEncryptionConfiguration",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "wisdom.knowledgebase.Tags": {
    "Required": "No",
    "Type": "List of [Tag",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  },
  "wisdom.knowledgebase.KnowledgeBaseType": {
    "Allowed values": "CUSTOM | EXTERNAL",
    "Required": "Yes",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "wisdom.knowledgebase.RenderingConfiguration": {
    "Required": "No",
    "Type": "RenderingConfiguration",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
