{
  "m2.environment.fsxstorageconfiguration.CfnAbout": "Defines the storage configuration for an Amazon FSx file system.",
  "m2.environment.fsxstorageconfiguration.CfnType": "AWS::M2::Environment.FsxStorageConfiguration",
  "m2.environment.fsxstorageconfiguration.CfnDocsKey": "aws-properties-m2-environment-fsxstorageconfiguration",
  "m2.environment.fsxstorageconfiguration.FileSystemId": {
    "Description": "The file system identifier.",
    "Required": "Yes",
    "Type": "String",
    "Pattern": "\\S{1,200}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "m2.environment.fsxstorageconfiguration.MountPoint": {
    "Description": "The mount point for the file system.",
    "Required": "Yes",
    "Type": "String",
    "Pattern": "\\S{1,200}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
