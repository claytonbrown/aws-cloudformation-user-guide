{
  "imagebuilder.distributionconfiguration.amidistributionconfiguration.CfnAbout": "Define and configure the output AMIs of the pipeline.",
  "imagebuilder.distributionconfiguration.amidistributionconfiguration.CfnType": "AWS::ImageBuilder::DistributionConfiguration.AmiDistributionConfiguration",
