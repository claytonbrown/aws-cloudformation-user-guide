{
  "quicksight.template.fontconfiguration.CfnAbout": "Configures the display properties of the given text.",
  "quicksight.template.fontconfiguration.CfnType": "AWS::QuickSight::Template.FontConfiguration",
  "quicksight.template.fontconfiguration.CfnDocsKey": "aws-properties-quicksight-template-fontconfiguration",
  "quicksight.template.fontconfiguration.FontColor": {
    "Description": "Determines the color of the text.",
    "Required": "No",
    "Type": "String",
    "Pattern": "^#[A-F0-9]{6}$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.template.fontconfiguration.FontDecoration": {
    "Description": "Determines the appearance of decorative lines on the text.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "NONE | UNDERLINE",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.template.fontconfiguration.FontSize": {
    "Description": "The option that determines the text display size.",
    "Required": "No",
    "Type": "FontSize",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.template.fontconfiguration.FontStyle": {
    "Description": "Determines the text display face that is inherited by the given font family.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "ITALIC | NORMAL",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.template.fontconfiguration.FontWeight": {
    "Description": "The option that determines the text display weight, or boldness.",
    "Required": "No",
    "Type": "FontWeight",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
