{
  "cloudformation.publisher.AcceptTermsAndConditions": {
    "Required": "Yes",
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "AllowedValues": [
      "True",
      "False"
    ]
  },
  "cloudformation.publisher.ConnectionArn": {
    "Pattern": "arn:aws(-[\\w]+)*:.+:.+:[0-9]{12}:.+",
    "Minimum": "1",
    "Required": "No",
    "Maximum": "256",
    "UpdateRequires": "Replacement"
  }
}
