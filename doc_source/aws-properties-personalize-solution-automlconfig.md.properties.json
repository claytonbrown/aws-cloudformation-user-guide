{
  "personalize.solution.automlconfig.CfnAbout": "When the solution performs AutoML (`performAutoML` is true in [CreateSolution](https://docs.aws.amazon.com/personalize/latest/dg/API_CreateSolution.html)), Amazon Personalize determines which recipe, from the specified list, optimizes the given metric. Amazon Personalize then uses that recipe for the solution.",
  "personalize.solution.automlconfig.CfnType": "AWS::Personalize::Solution.AutoMLConfig",
  "personalize.solution.automlconfig.CfnDocsKey": "aws-properties-personalize-solution-automlconfig",
