    "Description": "The metric to optimize.",
    "Required": "No",
    "Type": "String",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "personalize.solution.automlconfig.RecipeList": {
    "Description": "The list of candidate recipes.",
    "Required": "No",
    "Type": "List of String",
    "Maximum": "100",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
