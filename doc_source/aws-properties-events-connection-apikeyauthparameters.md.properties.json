  },
  "events.connection.apikeyauthparameters.ApiKeyValue": {
    "Description": "The value for the API key to use for authorization.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "^[ \\t]*[^\\x00-\\x1F:\\x7F]+([ \\t]+[^\\x00-\\x1F:\\x7F]+)*[ \\t]*$",
