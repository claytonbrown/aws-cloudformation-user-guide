{
  "auditmanager.assessment.AssessmentReportsDestination": {
    "Docs": "The destination that evidence reports are stored in for the assessment.",
    "Required": "No",
    "Type": "AssessmentReportsDestination",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.AwsAccount": {
    "Docs": "The AWS account that's associated with the assessment.",
    "Required": "No",
    "Type": "AWSAccount",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "auditmanager.assessment.Description": {
    "Docs": "The description of the assessment.",
    "Required": "No",
    "Type": "String",
    "Maximum": "1000",
    "Pattern": "^[\\w\\W\\s\\S]*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.FrameworkId": {
    "Docs": "The unique identifier for the framework.",
    "Required": "No",
    "Type": "String",
    "Minimum": "36",
    "Maximum": "36",
    "Pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "auditmanager.assessment.Name": {
    "Docs": "The name of the assessment.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "300",
    "Pattern": "^[^\\\\]*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.Roles": {
    "Docs": "The roles that are associated with the assessment.",
    "Required": "No",
    "Type": "List of [Role",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.Scope": {
    "Docs": "The wrapper of AWS accounts and services that are in scope for the assessment.",
    "Required": "No",
    "Type": "Scope",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.Status": {
    "Docs": "The overall status of the assessment.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "ACTIVE | INACTIVE",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "auditmanager.assessment.Tags": {
    "Docs": "The tags that are associated with the assessment.",
    "Required": "No",
    "Type": "List of [Tag",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)\n\n#"
  }
}
