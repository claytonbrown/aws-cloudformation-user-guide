{
  "acmpca.certificateauthority.customattribute.CfnAbout": "Defines the X.500 relative distinguished name (RDN).",
  "acmpca.certificateauthority.customattribute.CfnType": "AWS::ACMPCA::CertificateAuthority.CustomAttribute",
  "acmpca.certificateauthority.customattribute.CfnDocsKey": "aws-properties-acmpca-certificateauthority-customattribute",
  "acmpca.certificateauthority.customattribute.ObjectIdentifier": {
    "Description": "Specifies the object identifier (OID) of the attribute type of the relative distinguished name (RDN).",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "64",
    "Pattern": "^([0-2])\\.([0-9]|([0-3][0-9]))((\\.([0-9]+)){0,126})$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "acmpca.certificateauthority.customattribute.Value": {
    "Description": "Specifies the attribute value of relative distinguished name (RDN).",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
