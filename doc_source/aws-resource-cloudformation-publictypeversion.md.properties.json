{
  "cloudformation.publictypeversion.Arn": {
    "Required": "Conditional",
    "Type": "String",
    "Maximum": "1024",
    "Pattern": "arn:aws[A-Za-z0-9-]{0,64}:cloudformation:[A-Za-z0-9-]{1,64}:([0-9]{12})?:type/.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.publictypeversion.LogDeliveryBucket": {
    "Required": "No",
    "Minimum": "3",
    "Maximum": "63",
    "Pattern": "[\\s\\S]+",
    "UpdateRequires": "Replacement"
  },
  "cloudformation.publictypeversion.PublicVersionNumber": {
    "Required": "No",
    "Type": "String",
    "Minimum": "5",
    "Pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(.*)$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.publictypeversion.Type": {
    "Required": "Conditional",
    "Type": "String",
    "Allowed values": "HOOK | MODULE | RESOURCE",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.publictypeversion.TypeName": {
    "Required": "Conditional",
    "Type": "String",
    "Minimum": "10",
    "Maximum": "204",
    "Pattern": "[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}(::MODULE){0,1}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
