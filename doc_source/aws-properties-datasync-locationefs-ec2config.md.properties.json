{
  "datasync.locationefs.ec2config.SecurityGroupArns": {
    "Description": "The Amazon Resource Names (ARNs) of the security groups that are configured for the Amazon EC2 resource.",
    "Pattern": "^arn:(aws|aws-cn|aws-us-gov|aws-iso|aws-iso-b):ec2:[a-z\\-0-9]*:[0-9]{12}:security-group/.*$",
    "Required": "Yes",
    "Type": "List of String",
    "Maximum": "5",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "datasync.locationefs.ec2config.SubnetArn": {
    "Description": "The Amazon Resource Name (ARN) of the subnet that DataSync uses to access the target EFS file system.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "128",
    "Pattern": "^arn:(aws|aws-cn|aws-us-gov|aws-iso|aws-iso-b):ec2:[a-z\\-0-9]*:[0-9]{12}:subnet/.*$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
