{
  "cloudformation.typeactivation.loggingconfig.LogGroupName": {
    "Docs": "The Amazon CloudWatch Logs group to which CloudFormation sends error logging information when invoking the extension's handlers.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "[\\.\\-_/#A-Za-z0-9]+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.typeactivation.loggingconfig.LogRoleArn": {
    "Docs": "The Amazon Resource Name (ARN) of the role that CloudFormation should assume when sending log entries to CloudWatch Logs.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "256",
    "Pattern": "arn:.+:iam::[0-9]{12}:role/.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
