{
  "robomaker.robot.CfnAbout": "The `AWS::RoboMaker::RobotApplication` resource creates an AWS RoboMaker robot.",
  "robomaker.robot.CfnType": "AWS::RoboMaker::Robot",
  "robomaker.robot.CfnDocsKey": "aws-resource-robomaker-robot",
  "robomaker.robot.Architecture": {
    "Description": "The architecture of the robot.",
    "Required": "Yes",
    "Type": "String",
    "Allowed values": "ARM64 | ARMHF | X86_64",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "robomaker.robot.Fleet": {
    "Description": "The Amazon Resource Name (ARN) of the fleet to which the robot will be registered.",
    "Required": "No",
    "Type": "String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "robomaker.robot.GreengrassGroupId": {
    "Description": "The Greengrass group associated with the robot.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "1224",
    "Pattern": ".*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "robomaker.robot.Name": {
    "Description": "The name of the robot.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "255",
    "Pattern": "[a-zA-Z0-9_\\-]*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "robomaker.robot.Tags": {
    "Description": "A map that contains tag keys and tag values that are attached to the robot.",
    "Required": "No",
    "Type": "Map of String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)\n\n#"
  }
}
