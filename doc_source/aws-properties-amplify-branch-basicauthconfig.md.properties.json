{
  "amplify.branch.basicauthconfig.CfnAbout": "Use the BasicAuthConfig property type to set password protection for a specific branch.",
  "amplify.branch.basicauthconfig.CfnType": "AWS::Amplify::Branch.BasicAuthConfig",
  "amplify.branch.basicauthconfig.CfnDocsKey": "aws-properties-amplify-branch-basicauthconfig",
