  },
  "events.connection.basicauthparameters.Username": {
    "Description": "The user name to use for Basic authorization.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "^[ \\t]*[^\\x00-\\x1F:\\x7F]+([ \\t]+[^\\x00-\\x1F:\\x7F]+)*[ \\t]*$",
