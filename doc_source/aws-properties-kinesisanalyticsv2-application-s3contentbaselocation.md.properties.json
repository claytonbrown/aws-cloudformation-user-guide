{
  "kinesisanalyticsv2.application.s3contentbaselocation.CfnAbout": "The base location of the Amazon Data Analytics application.",
  "kinesisanalyticsv2.application.s3contentbaselocation.CfnType": "AWS::KinesisAnalyticsV2::Application.S3ContentBaseLocation",
  "kinesisanalyticsv2.application.s3contentbaselocation.CfnDocsKey": "aws-properties-kinesisanalyticsv2-application-s3contentbaselocation",
  "kinesisanalyticsv2.application.s3contentbaselocation.BasePath": {
    "Description": "The base path for the S3 bucket.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "1024",
    "Pattern": "[a-zA-Z0-9/!-_.*'()]+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "kinesisanalyticsv2.application.s3contentbaselocation.BucketARN": {
    "Description": "The Amazon Resource Name (ARN) of the S3 bucket.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "2048",
    "Pattern": "arn:.*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
