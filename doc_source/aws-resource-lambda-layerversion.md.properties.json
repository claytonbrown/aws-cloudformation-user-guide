{
  "lambda.layerversion.CompatibleArchitectures": {
    "Required": "No",
    "Type": "List of String",
    "Maximum": "2",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "lambda.layerversion.CompatibleRuntimes": {
    "Required": "No",
    "Type": "List of String",
    "Maximum": "15",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "lambda.layerversion.Content": {
    "Required": "Yes",
    "Type": "Content",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "lambda.layerversion.Description": {
    "Required": "No",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "256",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "lambda.layerversion.LayerName": {
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "140",
    "Pattern": "(arn:[a-zA-Z0-9-]+:lambda:[a-zA-Z0-9-]+:\\d{12}:layer:[a-zA-Z0-9-_]+)|[a-zA-Z0-9-_]+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "lambda.layerversion.LicenseInfo": {
    "Required": "No",
    "Type": "String",
    "Maximum": "512",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
