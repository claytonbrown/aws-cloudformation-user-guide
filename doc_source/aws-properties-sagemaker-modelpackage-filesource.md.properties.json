{
  "sagemaker.modelpackage.filesource.CfnAbout": "Contains details regarding the file source.",
  "sagemaker.modelpackage.filesource.CfnType": "AWS::SageMaker::ModelPackage.FileSource",
  "sagemaker.modelpackage.filesource.CfnDocsKey": "aws-properties-sagemaker-modelpackage-filesource",
  "sagemaker.modelpackage.filesource.ContentDigest": {
    "Description": "The digest of the file source.",
    "Required": "No",
    "Type": "String",
    "Maximum": "72",
    "Pattern": "^[Ss][Hh][Aa]256:[0-9a-fA-F]{64}$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "sagemaker.modelpackage.filesource.ContentType": {
    "Description": "The type of content stored in the file source.",
    "Required": "No",
    "Type": "String",
    "Maximum": "256",
    "Pattern": ".*",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "sagemaker.modelpackage.filesource.S3Uri": {
    "Description": "The Amazon S3 URI for the file source.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "1024",
    "Pattern": "^(https|s3)://([^/]+)/?(.*)$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
