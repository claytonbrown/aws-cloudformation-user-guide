{
  "acmpca.certificateauthority.accessmethod.AccessMethodType": {
    "Description": "Specifies the `AccessMethod`.",
    "Required": "No",
    "Type": "String",
    "Allowed values": "CA_REPOSITORY | RESOURCE_PKI_MANIFEST | RESOURCE_PKI_NOTIFY",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "acmpca.certificateauthority.accessmethod.CustomObjectIdentifier": {
    "Description": "An object identifier (OID) specifying the `AccessMethod`. The OID must satisfy the regular expression shown below. For more information, see NIST's definition of [Object Identifier (OID)](https://csrc.nist.gov/glossary/term/Object_Identifier).",
    "Required": "No",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "64",
    "Pattern": "^([0-2])\\.([0-9]|([0-3][0-9]))((\\.([0-9]+)){0,126})$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
