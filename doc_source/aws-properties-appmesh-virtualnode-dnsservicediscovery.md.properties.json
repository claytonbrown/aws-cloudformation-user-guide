{
  "appmesh.virtualnode.dnsservicediscovery.CfnAbout": "An object that represents the DNS service discovery information for your virtual node.",
  "appmesh.virtualnode.dnsservicediscovery.CfnType": "AWS::AppMesh::VirtualNode.DnsServiceDiscovery",
