{
  "shield.proactiveengagement.emergencycontact.CfnAbout": "Contact information that the SRT can use to contact you if you have proactive engagement enabled, for escalations to the SRT and to initiate proactive customer support.",
  "shield.proactiveengagement.emergencycontact.CfnType": "AWS::Shield::ProactiveEngagement.EmergencyContact",
  "shield.proactiveengagement.emergencycontact.CfnDocsKey": "aws-properties-shield-proactiveengagement-emergencycontact",
  "shield.proactiveengagement.emergencycontact.ContactNotes": {
    "Description": "Additional notes regarding the contact.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "1024",
    "Pattern": "^[\\w\\s\\.\\-,:/()+@]*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "shield.proactiveengagement.emergencycontact.EmailAddress": {
    "Description": "The email address for the contact.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "150",
    "Pattern": "^\\S+@\\S+\\.\\S+$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "shield.proactiveengagement.emergencycontact.PhoneNumber": {
    "Description": "The phone number for the contact.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "16",
    "Pattern": "^\\+[1-9]\\d{1,14}$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
