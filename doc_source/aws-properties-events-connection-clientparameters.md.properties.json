{
  "events.connection.clientparameters.CfnAbout": "Contains the OAuth authorization parameters to use for the connection.",
  "events.connection.clientparameters.CfnType": "AWS::Events::Connection.ClientParameters",
  "events.connection.clientparameters.CfnDocsKey": "aws-properties-events-connection-clientparameters",
  "events.connection.clientparameters.ClientID": {
    "Description": "The client ID to use for OAuth authorization.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "^[ \\t]*[^\\x00-\\x1F:\\x7F]+([ \\t]+[^\\x00-\\x1F:\\x7F]+)*[ \\t]*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "events.connection.clientparameters.ClientSecret": {
    "Description": "The client secret assciated with the client ID to use for OAuth authorization.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "^[ \\t]*[^\\x00-\\x1F:\\x7F]+([ \\t]+[^\\x00-\\x1F:\\x7F]+)*[ \\t]*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
