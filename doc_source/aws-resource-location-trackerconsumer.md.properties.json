{
  "location.trackerconsumer.TrackerName": {
    "Pattern": "^[-._\\w]+$",
    "Required": "Yes",
    "Maximum": "100",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "1",
    "Type": "String"
  },
  "location.trackerconsumer.ConsumerArn": {
    "Pattern": "^arn(:[a-z0-9]+([.-][a-z0-9]+)*){2}(:([a-z0-9]+([.-][a-z0-9]+)*)?){2}:([^/].*)?$",
    "Required": "Yes",
    "Maximum": "1600",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)",
    "Minimum": "0",
    "Type": "String"
  }
}
