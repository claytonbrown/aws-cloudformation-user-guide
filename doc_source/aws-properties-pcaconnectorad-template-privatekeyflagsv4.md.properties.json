{
  "pcaconnectorad.template.privatekeyflagsv4.CfnAbout": "Private key flags for v4 templates specify the client compatibility, if the private key can be exported, if user input is required when using a private key, if an alternate signature algorithm should be used, and if certificates are renewed using the same private key.",
  "pcaconnectorad.template.privatekeyflagsv4.CfnType": "AWS::PCAConnectorAD::Template.PrivateKeyFlagsV4",
  "pcaconnectorad.template.privatekeyflagsv4.CfnDocsKey": "aws-properties-pcaconnectorad-template-privatekeyflagsv4",
  "pcaconnectorad.template.privatekeyflagsv4.ClientVersion": {
    "Description": "Defines the minimum client compatibility.",
    "Required": "Yes",
    "Type": "String",
    "Allowed values": "WINDOWS_SERVER_2012 | WINDOWS_SERVER_2012_R2 | WINDOWS_SERVER_2016",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "pcaconnectorad.template.privatekeyflagsv4.ExportableKey": {
    "Description": "Allows the private key to be exported.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "pcaconnectorad.template.privatekeyflagsv4.RequireAlternateSignatureAlgorithm": {
    "Description": "Requires the PKCS #1 v2.1 signature format for certificates. You should verify that your CA, objects, and applications can accept this signature format.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "pcaconnectorad.template.privatekeyflagsv4.RequireSameKeyRenewal": {
    "Description": "Renew certificate using the same private key.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "pcaconnectorad.template.privatekeyflagsv4.StrongKeyProtectionRequired": {
    "Description": "Require user input when using the private key for enrollment.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "pcaconnectorad.template.privatekeyflagsv4.UseLegacyProvider": {
    "Description": "Specifies the cryptographic service provider category used to generate private keys. Set to TRUE to use Legacy Cryptographic Service Providers and FALSE to use Key Storage Providers.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
