{
  "apprunner.service.imagerepository.ImageIdentifier": {
    "Pattern": "([0-9]{12}.dkr.ecr.[a-z\\-]+-[0-9]{1}.amazonaws.com\\/.*)|(^public\\.ecr\\.aws\\/.+\\/.+)",
    "Minimum": "1",
    "Required": "Yes",
    "Maximum": "1024",
    "UpdateRequires": "No interruption"
  },
  "apprunner.service.imagerepository.ImageRepositoryType": {
    "Allowed values": "ECR | ECR_PUBLIC",
    "Required": "Yes",
    "Type": "String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "apprunner.service.imagerepository.ImageConfiguration": {
    "Required": "No",
    "Type": "ImageConfiguration",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
