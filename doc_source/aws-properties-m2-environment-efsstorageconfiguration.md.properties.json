{
  "m2.environment.efsstorageconfiguration.CfnAbout": "Defines the storage configuration for an Amazon EFS file system.",
  "m2.environment.efsstorageconfiguration.CfnType": "AWS::M2::Environment.EfsStorageConfiguration",
  "m2.environment.efsstorageconfiguration.CfnDocsKey": "aws-properties-m2-environment-efsstorageconfiguration",
  "m2.environment.efsstorageconfiguration.FileSystemId": {
    "Description": "The file system identifier.",
    "Required": "Yes",
    "Type": "String",
    "Pattern": "\\S{1,200}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "m2.environment.efsstorageconfiguration.MountPoint": {
    "Description": "The mount point for the file system.",
    "Required": "Yes",
    "Type": "String",
    "Pattern": "\\S{1,200}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
