{
  "eks.nodegroup.taint.CfnAbout": "A property that allows a node to repel a set of pods. For more information, see [Node taints on managed node groups](https://docs.aws.amazon.com/eks/latest/userguide/node-taints-managed-node-groups.html).",
  "eks.nodegroup.taint.CfnType": "AWS::EKS::Nodegroup.Taint",
