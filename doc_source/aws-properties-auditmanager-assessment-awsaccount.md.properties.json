{
  "auditmanager.assessment.awsaccount.EmailAddress": {
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "320",
    "Pattern": "^.*@.*$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "auditmanager.assessment.awsaccount.Id": {
    "Required": "No",
    "Type": "String",
    "Minimum": "12",
    "Maximum": "12",
    "Pattern": "^[0-9]{12}$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "auditmanager.assessment.awsaccount.Name": {
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "50",
    "Pattern": "^[\\u0020-\\u007E]+$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
