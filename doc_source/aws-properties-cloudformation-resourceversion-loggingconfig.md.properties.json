{
  "cloudformation.resourceversion.loggingconfig.CfnAbout": "Logging configuration information for a resource.",
  "cloudformation.resourceversion.loggingconfig.CfnType": "AWS::CloudFormation::ResourceVersion.LoggingConfig",
  "cloudformation.resourceversion.loggingconfig.CfnDocsKey": "aws-properties-cloudformation-resourceversion-loggingconfig",
  "cloudformation.resourceversion.loggingconfig.LogGroupName": {
    "Description": "The Amazon CloudWatch logs group to which CloudFormation sends error logging information when invoking the type's handlers.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "512",
    "Pattern": "[\\.\\-_/#A-Za-z0-9]+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cloudformation.resourceversion.loggingconfig.LogRoleArn": {
    "Description": "The ARN of the role that CloudFormation should assume when sending log entries to CloudWatch logs.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "256",
    "Pattern": "arn:.+:iam::[0-9]{12}:role/.+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
