{
  "customerprofiles.integration.salesforcesourceproperties.CfnAbout": "The properties that are applied when Salesforce is being used as a source.",
  "customerprofiles.integration.salesforcesourceproperties.CfnType": "AWS::CustomerProfiles::Integration.SalesforceSourceProperties",
  "customerprofiles.integration.salesforcesourceproperties.CfnDocsKey": "aws-properties-customerprofiles-integration-salesforcesourceproperties",
  "customerprofiles.integration.salesforcesourceproperties.EnableDynamicFieldUpdate": {
    "Description": "The flag that enables dynamic fetching of new (recently added) fields in the Salesforce objects while running a flow.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "customerprofiles.integration.salesforcesourceproperties.IncludeDeletedRecords": {
    "Description": "Indicates whether Amazon AppFlow includes deleted files in the flow run.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "customerprofiles.integration.salesforcesourceproperties.Object": {
    "Description": "The object specified in the Salesforce flow source.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "512",
    "Pattern": "\\S+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
