{
  "events.apidestination.InvocationRateLimitPerSecond": {
    "Minimum": "1",
    "Required": "No",
    "Type": "Integer",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "events.apidestination.Name": {
    "Pattern": "[\\.\\-_A-Za-z0-9]+",
    "Required": "No",
    "Maximum": "64",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#",
    "Minimum": "1",
    "Type": "String"
  },
  "events.apidestination.Description": {
    "Pattern": ".*",
    "Required": "No",
    "Type": "String",
    "Maximum": "512",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "events.apidestination.HttpMethod": {
    "Allowed values": "DELETE | GET | HEAD | OPTIONS | PATCH | POST | PUT",
    "Required": "Yes",
    "Type": "String",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "events.apidestination.InvocationEndpoint": {
    "Pattern": "^((%[0-9A-Fa-f]{2}|[-()_.!~*';/?:@\\x26=+$,A-Za-z0-9])+)([).!';/?:,])?$",
    "Required": "Yes",
    "Maximum": "2048",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)",
    "Minimum": "1",
    "Type": "String"
  },
  "events.apidestination.ConnectionArn": {
    "Pattern": "^arn:aws([a-z]|\\-)*:events:([a-z]|\\d|\\-)*:([0-9]{12})?:connection\\/[\\.\\-_A-Za-z0-9]+\\/[\\-A-Za-z0-9]+$",
    "Required": "Yes",
    "Maximum": "1600",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)",
    "Minimum": "1",
    "Type": "String"
  }
}
