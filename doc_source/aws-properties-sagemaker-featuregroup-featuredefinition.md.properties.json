{
  "sagemaker.featuregroup.featuredefinition.FeatureName": {
    "Docs": "The name of a feature. The type must be a string. `FeatureName` cannot be any of the following: `is_deleted`, `write_time`, `api_invocation_time`.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "64",
    "Pattern": "^[a-zA-Z0-9]([-_]*[a-zA-Z0-9]){0,63}",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "sagemaker.featuregroup.featuredefinition.FeatureType": {
    "Docs": "The value type of a feature. Valid values are Integral, Fractional, or String.",
    "Required": "Yes",
    "Type": "String",
    "Allowed values": "Fractional | Integral | String",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
