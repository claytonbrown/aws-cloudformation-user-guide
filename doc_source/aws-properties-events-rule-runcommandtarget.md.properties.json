{
  "events.rule.runcommandtarget.Key": {
    "Docs": "Can be either `tag:` *tag-key* or `InstanceIds`.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "128",
    "Pattern": "^[\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*$",
    "UpdateRequires": "No interruption"
  },
  "events.rule.runcommandtarget.Values": {
    "Docs": "If `Key` is `tag:` *tag-key*, `Values` is a list of tag values. If `Key` is `InstanceIds`, `Values` is a list of Amazon EC2 instance IDs.",
    "Required": "Yes",
    "Type": "List of String",
    "Maximum": "50",
    "UpdateRequires": "No interruption"
  }
}
