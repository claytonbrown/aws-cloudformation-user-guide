{
  "appflow.connectorprofile.basicauthcredentials.CfnAbout": "The basic auth credentials required for basic authentication.",
  "appflow.connectorprofile.basicauthcredentials.CfnType": "AWS::AppFlow::ConnectorProfile.BasicAuthCredentials",
  "appflow.connectorprofile.basicauthcredentials.CfnDocsKey": "aws-properties-appflow-connectorprofile-basicauthcredentials",
  "appflow.connectorprofile.basicauthcredentials.Password": {
    "Description": "The password to use to connect to a resource.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "512",
    "Pattern": ".*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.connectorprofile.basicauthcredentials.Username": {
    "Description": "The username to use to connect to a resource.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "512",
    "Pattern": "\\S+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
