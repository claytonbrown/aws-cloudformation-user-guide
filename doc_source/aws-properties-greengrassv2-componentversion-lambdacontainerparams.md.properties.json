{
  "greengrassv2.componentversion.lambdacontainerparams.CfnAbout": "Contains information about a container in which AWS Lambda functions run on Greengrass core devices.",
  "greengrassv2.componentversion.lambdacontainerparams.CfnType": "AWS::GreengrassV2::ComponentVersion.LambdaContainerParams",
  "greengrassv2.componentversion.lambdacontainerparams.CfnDocsKey": "aws-properties-greengrassv2-componentversion-lambdacontainerparams",
  "greengrassv2.componentversion.lambdacontainerparams.Devices": {
    "Description": "The list of system devices that the container can access.",
    "Required": "No",
    "Type": "List of [LambdaDeviceMount",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "greengrassv2.componentversion.lambdacontainerparams.MemorySizeInKB": {
    "Description": "The memory size of the container, expressed in kilobytes.  Default: `16384` (16 MB)",
    "Required": "No",
    "Type": "Integer",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "greengrassv2.componentversion.lambdacontainerparams.MountROSysfs": {
