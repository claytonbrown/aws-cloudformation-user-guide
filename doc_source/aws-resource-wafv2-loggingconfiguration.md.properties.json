{
  "wafv2.loggingconfiguration.LogDestinationConfigs": {
    "Required": "Yes",
    "Type": "List of String",
    "Maximum": "100",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "wafv2.loggingconfiguration.LoggingFilter": {
    "Required": "No",
    "Type": "Json",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "wafv2.loggingconfiguration.RedactedFields": {
    "Required": "No",
    "Type": "List of [FieldToMatch",
    "Maximum": "100",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "wafv2.loggingconfiguration.ResourceArn": {
    "Pattern": ".*\\S.*",
    "Required": "Yes",
    "Maximum": "2048",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#",
    "Minimum": "20",
    "Type": "String"
  }
}
