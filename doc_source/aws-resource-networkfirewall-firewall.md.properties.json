{
  "networkfirewall.firewall.DeleteProtection": {
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.Description": {
    "Required": "No",
    "Type": "String",
    "Maximum": "512",
    "Pattern": "^.*$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.FirewallName": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "128",
    "Pattern": "^[a-zA-Z0-9-]+$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "networkfirewall.firewall.FirewallPolicyArn": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "256",
    "Pattern": "^arn:aws.*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.FirewallPolicyChangeProtection": {
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.SubnetChangeProtection": {
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.SubnetMappings": {
    "Required": "Yes",
    "Type": "List of [SubnetMapping",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.Tags": {
    "Required": "No",
    "Type": "List of [Tag",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "networkfirewall.firewall.VpcId": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "128",
    "Pattern": "^vpc-[0-9a-f]+$",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
