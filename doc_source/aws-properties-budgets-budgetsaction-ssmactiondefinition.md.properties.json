{
  "budgets.budgetsaction.ssmactiondefinition.CfnAbout": "The Amazon EC2 Systems Manager (SSM) action definition details.",
  "budgets.budgetsaction.ssmactiondefinition.CfnType": "AWS::Budgets::BudgetsAction.SsmActionDefinition",
