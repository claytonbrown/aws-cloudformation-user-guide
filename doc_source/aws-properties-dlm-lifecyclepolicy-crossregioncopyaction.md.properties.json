{
  "dlm.lifecyclepolicy.crossregioncopyaction.CfnAbout": "Specifies a rule for copying shared snapshots across Regions.",
  "dlm.lifecyclepolicy.crossregioncopyaction.CfnType": "AWS::DLM::LifecyclePolicy.CrossRegionCopyAction",
  "dlm.lifecyclepolicy.crossregioncopyaction.CfnDocsKey": "aws-properties-dlm-lifecyclepolicy-crossregioncopyaction",
  "dlm.lifecyclepolicy.crossregioncopyaction.EncryptionConfiguration": {
    "Description": "The encryption settings for the copied snapshot.",
    "Required": "Yes",
    "Type": "EncryptionConfiguration",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "dlm.lifecyclepolicy.crossregioncopyaction.RetainRule": {
    "Description": "Specifies the retention rule for cross-Region snapshot copies.",
    "Required": "No",
    "Type": "CrossRegionCopyRetainRule",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "dlm.lifecyclepolicy.crossregioncopyaction.Target": {
    "Description": "The target Region.",
    "Required": "Yes",
    "Type": "String",
    "Minimum": "0",
    "Maximum": "2048",
    "Pattern": "^[\\w:\\-\\/\\*]+$",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
