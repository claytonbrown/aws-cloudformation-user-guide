{
  "timestream.scheduledquery.s3configuration.BucketName": {
    "Required": "Yes",
    "Type": "String",
    "Minimum": "3",
    "Maximum": "63",
    "Pattern": "[a-z0-9][\\.\\-a-z0-9]{1,61}[a-z0-9]",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "timestream.scheduledquery.s3configuration.EncryptionOption": {
    "Required": "No",
    "Type": "String",
    "Allowed values": "SSE_KMS | SSE_S3",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "timestream.scheduledquery.s3configuration.ObjectKeyPrefix": {
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "928",
    "Pattern": "[a-zA-Z0-9|!\\-_*'\\(\\)]([a-zA-Z0-9]|[!\\-_*'\\(\\)\\/.])+",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
