{
  "route53resolver.resolverqueryloggingconfig.DestinationArn": {
    "Docs": "The ARN of the resource that you want Resolver to send query logs: an Amazon S3 bucket, a CloudWatch Logs log group, or a Kinesis Data Firehose delivery stream.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "600",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "route53resolver.resolverqueryloggingconfig.Name": {
    "Docs": "The name of the query logging configuration.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "64",
    "Pattern": "(?!^[0-9]+$)([a-zA-Z0-9\\-_' ']+)",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)\n\n#"
  }
}
