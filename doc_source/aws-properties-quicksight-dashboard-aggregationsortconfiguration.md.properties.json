{
  "quicksight.dashboard.aggregationsortconfiguration.CfnAbout": "The configuration options to sort aggregated values.",
  "quicksight.dashboard.aggregationsortconfiguration.CfnType": "AWS::QuickSight::Dashboard.AggregationSortConfiguration",
