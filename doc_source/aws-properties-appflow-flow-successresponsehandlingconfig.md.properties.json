{
  "appflow.flow.successresponsehandlingconfig.CfnAbout": "Determines how Amazon AppFlow handles the success response that it gets from the connector after placing data.\n\nFor example, this setting would determine where to write the response from the destination connector upon a successful insert operation.",
  "appflow.flow.successresponsehandlingconfig.CfnType": "AWS::AppFlow::Flow.SuccessResponseHandlingConfig",
