{
  "appflow.flow.veevasourceproperties.CfnAbout": "The properties that are applied when using Veeva as a flow source.",
  "appflow.flow.veevasourceproperties.CfnType": "AWS::AppFlow::Flow.VeevaSourceProperties",
  "appflow.flow.veevasourceproperties.CfnDocsKey": "aws-properties-appflow-flow-veevasourceproperties",
  "appflow.flow.veevasourceproperties.DocumentType": {
    "Description": "The document type specified in the Veeva document extract flow.",
    "Required": "No",
    "Type": "String",
    "Maximum": "512",
    "Pattern": "[\\s\\w_-]+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.veevasourceproperties.IncludeAllVersions": {
    "Description": "Boolean value to include All Versions of files in Veeva document extract flow.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.veevasourceproperties.IncludeRenditions": {
    "Description": "Boolean value to include file renditions in Veeva document extract flow.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.veevasourceproperties.IncludeSourceFiles": {
    "Description": "Boolean value to include source files in Veeva document extract flow.",
    "Required": "No",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "appflow.flow.veevasourceproperties.Object": {
    "Description": "The object specified in the Veeva flow source.",
    "Required": "Yes",
    "Type": "String",
    "Maximum": "512",
    "Pattern": "\\S+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)\n\n#"
  }
}
