{
  "cleanrooms.collaboration.dataencryptionmetadata.CfnAbout": "The settings for client-side encryption for cryptographic computing.",
  "cleanrooms.collaboration.dataencryptionmetadata.CfnType": "AWS::CleanRooms::Collaboration.DataEncryptionMetadata",
  "cleanrooms.collaboration.dataencryptionmetadata.CfnDocsKey": "aws-properties-cleanrooms-collaboration-dataencryptionmetadata",
  "cleanrooms.collaboration.dataencryptionmetadata.AllowCleartext": {
    "Description": "Indicates whether encrypted tables can contain cleartext data (true) or are to cryptographically process every column (false).",
    "Required": "Yes",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cleanrooms.collaboration.dataencryptionmetadata.AllowDuplicates": {
    "Description": "Indicates whether Fingerprint columns can contain duplicate entries (true) or are to contain only non-repeated values (false).",
    "Required": "Yes",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cleanrooms.collaboration.dataencryptionmetadata.AllowJoinsOnColumnsWithDifferentNames": {
    "Description": "Indicates whether Fingerprint columns can be joined on any other Fingerprint column with a different name (true) or can only be joined on Fingerprint columns of the same name (false).",
    "Required": "Yes",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  },
  "cleanrooms.collaboration.dataencryptionmetadata.PreserveNulls": {
    "Description": "Indicates whether NULL values are to be copied as NULL to encrypted tables (true) or cryptographically processed (false).",
    "Required": "Yes",
    "AllowedValues": [
      "True",
      "False"
    ],
    "Type": "Boolean",
    "UpdateRequires": "[Replacement](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-replacement)"
  }
}
