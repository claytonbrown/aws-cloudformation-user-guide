{
  "quicksight.analysis.sheet.Name": {
    "Docs": "The name of a sheet. This name is displayed on the sheet's tab in the Amazon QuickSight console.",
    "Required": "No",
    "Type": "String",
    "Pattern": ".*\\S.*",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  },
  "quicksight.analysis.sheet.SheetId": {
    "Docs": "The unique identifier associated with a sheet.",
    "Required": "No",
    "Type": "String",
    "Minimum": "1",
    "Maximum": "2048",
    "Pattern": "[\\w\\-]+",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)"
  }
}
