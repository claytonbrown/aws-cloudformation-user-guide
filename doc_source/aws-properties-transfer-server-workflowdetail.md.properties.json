{
  "transfer.server.workflowdetail.WorkflowId": {
    "Pattern": "^w-([a-z0-9]{17})$",
    "Required": "Yes",
    "Maximum": "19",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)",
    "Minimum": "19",
    "Type": "String"
  },
  "transfer.server.workflowdetail.ExecutionRole": {
    "Pattern": "arn:.*role/.*",
    "Required": "Yes",
    "Maximum": "2048",
    "UpdateRequires": "[No interruption](https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/using-cfn-updating-stacks-update-behaviors.html#update-no-interrupt)",
    "Minimum": "20",
    "Type": "String"
  }
}
